# =========================================================================
# MockPrep AI Environment Configuration Template
# =========================================================================
# Copy this file to a new file named '.env' and fill in your actual values.
# Do NOT commit '.env' to your version control repository (Git).
# =========================================================================

# 1. Server Configuration
# The port the backend Express server will bind to. (Default is 3001)
PORT=3001

# 2. AI Model Keys (Groq Cloud API)
# Paste your Groq API key here. It should start with 'gsk_'.
# You can obtain a free API key by signing up at: https://console.groq.com/
# Example value: GSK_API_KEY=gsk_LqA88Hj... (DO NOT share this key)
GROQ_API_KEY=gsk_your_groq_api_key_here

# 3. Local LLM Fallback (Ollama)
# If no GROQ_API_KEY is provided, or if the API limit is exceeded, the server
# automatically falls back to Ollama.
#
# Requirements:
# - Download and install Ollama from: https://ollama.com/
# - Ensure Ollama is running locally (listens at http://localhost:11434 by default).
# - Pre-pull the llama3.2 model by running this command in your terminal:
#   $ ollama pull llama3.2

# 4. MongoDB Configuration
# Provide the connection URI for your MongoDB database (local or cloud Atlas instance).
MONGODB_URI=mongodb://localhost:27017/mockprep

# 5. Firebase Admin SDK Configuration (Backend Verification)
# Used by the backend to verify client JWT ID tokens.
# Format: Put project id, service account email, and private key.
# Private key should include newline markers: "-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ..."
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-details\n-----END PRIVATE KEY-----\n"

# 6. Firebase Client SDK Configuration (Frontend Authentication)
# Used by the Vite frontend app. Prefix variables with VITE_ to make them available to React.
# NOTE: To use Google Sign-In:
# 1. Open the Firebase Console (https://console.firebase.google.com/)
# 2. Go to Authentication -> Sign-in method -> Add new provider -> Enable 'Google'.
# 3. No extra environment variables are needed; it uses the client configuration below.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# 7. Connected Platforms Configuration (Optional)
# A GitHub personal access token (classic or fine-grained) can be provided
# to raise the rate limit for GitHub API requests from 60/hour (unauthenticated)
# to 5000/hour. Create a token in GitHub developer settings: Settings -> Developer Settings -> Personal access tokens
GITHUB_TOKEN=your_github_personal_access_token_here

